# PlantNet API Key
# Get your free API key at https://my.plantnet.org/
EXPO_PUBLIC_PLANTNET_API_KEY=2b10YGWFXzXR9tQSs4TYgt8B0e

# RevenueCat API Key
# Get your API key from https://app.revenuecat.com/
# NOTE: Replace 'pub_YOUR_KEY_HERE' with your actual RevenueCat public API key
REVENUECAT_API_KEY=pub_YOUR_KEY_HERE

# AdMob App IDs
# Get your App IDs from https://apps.admob.com/
# NOTE: Replace these placeholder values with your actual AdMob App IDs
# Android App ID format: ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
# iOS App ID format: ca-app-pub-XXXXXXXXXXXXXXXX~ZZZZZZZZZZ
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511

# AdMob Banner Ad Unit IDs (replace with real IDs from AdMob console)
# Test IDs: ca-app-pub-3940256099942544/6300978111 (Android) or ca-app-pub-3940256099942544/2934735716 (iOS)
EXPO_PUBLIC_ADMOB_IOS_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/ZZZZZZZZZZ
EXPO_PUBLIC_ADMOB_ANDROID_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY

# Supabase Configuration
# Get your project URL and anon key from https://supabase.com/dashboard
# NOTE: Replace these placeholder values with your actual Supabase project credentials
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
